jobs:
  patch:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Download patch tool
        run: |
          wget -O vbmeta-disable-verification https://github.com/libxzr/vbmeta-disable-verification/releases/download/v1.0/vbmeta-disable-verification-linux
          chmod +x vbmeta-disable-verification

      - name: Patch vbmeta
        run: |
          ./vbmeta-disable-verification vbmeta.img
        shell: bash

      - name: Upload patched vbmeta
        uses: actions/upload-artifact@v3
        with:
          name: vbmeta_patched.img
